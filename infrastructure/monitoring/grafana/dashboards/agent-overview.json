{
  "annotations": { "list": [] },
  "description": "WanderPlan AI — Per-Agent Dashboard (replaces CloudWatch per-service dashboards)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Agent Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(up{job=~\"orchestrator|specialist-agents\"} == 1)",
          "legendFormat": "Healthy Agents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 12 },
              { "color": "green", "value": 15 }
            ]
          },
          "unit": "short",
          "max": 15
        }
      }
    },
    {
      "title": "Request Rate per Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"orchestrator|specialist-agents\"}[5m])) by (instance)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Response Latency p95 per Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"orchestrator|specialist-agents\"}[5m])) by (le, instance))",
          "legendFormat": "{{ instance }} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate per Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",job=~\"orchestrator|specialist-agents\"}[5m])) by (instance) / sum(rate(http_requests_total{job=~\"orchestrator|specialist-agents\"}[5m])) by (instance)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "LLM API Call Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }} p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{ model }} p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Kafka Consumer Lag by Agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "kafka_consumer_group_lag",
          "legendFormat": "{{ group }} / {{ topic }}"
        }
      ]
    },
    {
      "title": "Kafka Messages/sec by Topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(kafka_topic_messages_total[5m])) by (topic)",
          "legendFormat": "{{ topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"wanderplan-.*\"}[5m]) * 100",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"wanderplan-.*\"} / 1024 / 1024",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "title": "Redis Memory & Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used Memory (MB)"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        }
      ]
    },
    {
      "title": "PostgreSQL Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "pg_replication_lag_seconds",
          "legendFormat": "Replication Lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Planning State Machine — Active Trips by Stage",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "sum(trip_current_stage_total) by (stage)",
          "legendFormat": "{{ stage }}"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["wanderplan", "agents", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WanderPlan AI — Agent Overview",
  "uid": "wanderplan-agent-overview"
}
