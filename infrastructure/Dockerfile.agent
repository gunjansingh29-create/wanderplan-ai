# =============================================================================
# WanderPlan AI - Agent Microservice Dockerfile
# Shared base image for all 15 agent services
# =============================================================================

FROM python:3.12-slim AS base

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Application code
COPY schemas/ schemas/
COPY models/ models/
COPY services/ services/
COPY core/ core/
COPY agents/ agents/
COPY config/ config/

# Health check
HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD curl -f http://localhost:${AGENT_PORT:-8000}/health || exit 1

# Default command (overridden per agent in docker-compose.yml)
CMD ["uvicorn", "agents.orchestrator:app", "--host", "0.0.0.0", "--port", "8000"]
