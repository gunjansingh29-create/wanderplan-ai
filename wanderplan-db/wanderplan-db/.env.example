# ══════════════════════════════════════════════
# WanderPlan AI — Database Environment Variables
# ══════════════════════════════════════════════

# PostgreSQL Primary (via PgBouncer)
DATABASE_URL="postgresql://svc_api:password@localhost:6432/wanderplan?schema=public"

# PostgreSQL Read Replica (via PgBouncer)
DATABASE_REPLICA_URL="postgresql://svc_api:password@localhost:6432/wanderplan_replica?schema=public"

# Direct connection (bypass PgBouncer — for migrations only)
DIRECT_DATABASE_URL="postgresql://wanderplan_admin:password@pg-primary.internal:5432/wanderplan"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
