{
  "name": "wanderplan-ai",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "workspaceFolder": "/workspaces/wanderplan-ai",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/wanderplan-ai,type=bind,consistency=cached",
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash",
    "python.defaultInterpreterPath": "/usr/local/bin/python"
  },
  "extensions": [
    "ms-azuretools.vscode-docker",
    "redhat.vscode-yaml",
    "github.vscode-pull-request-github",
    "eamodio.gitlens",
    "ms-vscode-remote.remote-containers",
    "ms-python.python",
    "ms-python.vscode-pylance",
    "esbenp.prettier-vscode"
  ],
  "forwardPorts": [8000, 3000, 8080, 9001],
  "postCreateCommand": "pip install -r requirements.txt || true",
  "remoteUser": "vscode"
}
