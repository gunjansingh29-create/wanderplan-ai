{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "k6 metrics InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" }
  ],
  "description": "WanderPlan AI k6 Performance Test Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Response Time",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 3000 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT percentile(\"value\", 50) as \"p50\", percentile(\"value\", 95) as \"p95\", percentile(\"value\", 99) as \"p99\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT non_negative_derivative(max(\"value\"), 1s) as \"RPS\" FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A"
        }
      ],
      "title": "Requests Per Second",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "thresholds", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT mean(\"value\") FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A"
        }
      ],
      "title": "Active Virtual Users",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red",    "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "thresholds" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"response_time_drift\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A"
        }
      ],
      "title": "Response Time Drift (soak)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Custom Metrics",
      "type": "row"
    },
    {
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"kafka_message_latency\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A",
          "alias": "Kafka p95"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"agent_response_time\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "B",
          "alias": "Agent p95"
        }
      ],
      "title": "Kafka & Agent Latency (p95)",
      "type": "timeseries"
    },
    {
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT percentile(\"value\", 95) FROM \"ws_message_delivery_latency\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A",
          "alias": "WS delivery p95"
        }
      ],
      "title": "WebSocket Message Delivery Latency (p95)",
      "type": "timeseries"
    },
    {
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"value\") FROM \"storyboard_queue_depth\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "A",
          "alias": "Storyboard queue"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT last(\"value\") FROM \"sync_queue_depth\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
          "refId": "B",
          "alias": "Sync queue"
        }
      ],
      "title": "Queue Depths",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "graphMode": "area", "colorMode": "thresholds" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT sum(\"value\") FROM \"db_pool_exhaustion_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(0)",
          "refId": "A",
          "alias": "DB pool errors"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "SELECT sum(\"value\") FROM \"calendar_rate_limit_errors\" WHERE $timeFilter GROUP BY time($__interval) fill(0)",
          "refId": "B",
          "alias": "Cal rate-limit errors"
        }
      ],
      "title": "Infrastructure Errors",
      "type": "stat"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["k6", "wanderplan", "performance"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WanderPlan AI — k6 Performance Tests",
  "uid": "wanderplan-perf",
  "version": 1
}
